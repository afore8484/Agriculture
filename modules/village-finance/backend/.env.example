# village-finance backend environment template

# application
APP_NAME=village-finance-backend
APP_ENV=development
APP_PORT=48080
SPRING_PROFILES_ACTIVE=dev

# database
DB_TYPE=postgresql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=village_finance_dev
DB_USER=village_finance
DB_PASSWORD=replace-me
DB_SCHEMA=village_finance_ops
DB_COMPAT_TARGET=postgresql,kingbase

# cache / queue
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
MQ_URL=

# storage
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# external integrations
BANK_LINK_BASE_URL=
BANK_LINK_APP_KEY=
BANK_LINK_APP_SECRET=

# security
JWT_SECRET=
